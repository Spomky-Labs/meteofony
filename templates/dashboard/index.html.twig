{% extends 'base.html.twig' %}

{% block title %}Community Records{% endblock %}

{% block content %}
    <div class="container mx-auto px-4 py-12 max-w-4xl">
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-base-content mb-2">
                <i class="fa-solid fa-location-dot text-primary"></i>
                Choose a City
            </h1>
            <p class="text-base-content/60">Search for any city in France to access real-time weather measurements</p>
            <div class="divider max-w-xs mx-auto"></div>
        </div>

        <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
                <div class="alert alert-info mb-6">
                    <i class="fa-solid fa-circle-info"></i>
                    <p>View temperature, humidity, wind speed, and more from local weather stations across our community network.</p>
                </div>

                {{ component('search_cities') }}
            </div>
        </div>
    </div>
{% endblock %}
