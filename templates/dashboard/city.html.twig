{% extends 'base.html.twig' %}

{% block title %}Surveys of {{ city.name }}{% endblock %}

{% block content %}
    <div class="container mx-auto px-4 py-12 max-w-6xl">
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-base-content mb-2">
                <i class="fa-solid fa-city text-primary"></i>
                {{ city.name }}
            </h1>
            {% if city.zipCode is not null %}
                <span class="badge badge-primary badge-lg">{{ city.zipCode }}</span>
            {% endif %}
            <div class="divider max-w-xs mx-auto"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="card bg-base-100 shadow-lg">
                <div class="card-body">
                    <h2 class="card-title text-xl">
                        <i class="fa-solid fa-map-location-dot text-secondary"></i>
                        Location
                    </h2>
                    {{ ux_map(map, {
                        id: 'map',
                        class: 'rounded-lg overflow-hidden w-full h-96 mt-4',
                        style: 'height: 400px; width: 100%;'
                    }) }}
                </div>
            </div>

            <div class="card bg-base-100 shadow-lg">
                <div class="card-body">
                    <h2 class="card-title text-xl">
                        <i class="fa-solid fa-chart-line text-accent"></i>
                        Weather Data
                    </h2>
                    <div class="mt-4">
                        {{ render_chart(chart) }}
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-8">
            <a href="{{ path('app_dashboard') }}" class="btn btn-outline btn-primary gap-2">
                <i class="fa-solid fa-arrow-left"></i>
                Back to Dashboard
            </a>
        </div>
    </div>
{% endblock %}
