{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block nav %}{% endblock %}
{% block footer %}{% endblock %}
{% block bodytags %}class="bg-base-100 h-screen overflow-hidden"{% endblock %}

{% block body %}
    <div class="hero h-screen bg-base-200">
        <div class="hero-content flex-col lg:flex-row-reverse max-w-6xl w-full">
            <div class="flex-1 text-center lg:text-left">
                <img
                    src="{{ asset('images/Authentication-bro.svg') }}"
                    class="max-w-lg mx-auto drop-shadow-2xl"
                    alt="Reset password illustration"
                />
            </div>
            <div class="flex-1">
                <div class="card bg-base-100 shadow-2xl">
                    <div class="card-body">
                        <h1 class="text-4xl font-bold text-center mb-6">
                            <i class="fa-solid fa-lock-open text-primary"></i>
                            Reset Your Password
                        </h1>

                        <div class="alert alert-info mb-6">
                            <i class="fa-solid fa-circle-info"></i>
                            <p>Choose a new secure password for your account.</p>
                        </div>

                        {{ form_start(resetForm) }}
                            <div class="form-control mb-4">
                                <label class="label">
                                    <span class="label-text font-semibold">New Password</span>
                                </label>
                                {{ form_widget(resetForm.plainPassword, {attr: {class: 'input input-bordered input-primary', placeholder: 'Enter your new password'}}) }}
                                {{ form_errors(resetForm.plainPassword) }}
                            </div>

                            <div class="form-control mt-6">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fa-solid fa-key"></i>
                                    Reset Password
                                </button>
                            </div>

                            <div class="divider">OR</div>

                            <div class="text-center space-y-2">
                                <a href="{{ path('app_login') }}" class="link link-primary">
                                    <i class="fa-solid fa-arrow-left"></i>
                                    Return to the login page
                                </a>
                                <br>
                                <a href="{{ path('app_homepage') }}" class="link link-hover link-primary text-sm">
                                    <i class="fa-solid fa-house"></i>
                                    Back to Homepage
                                </a>
                            </div>
                        {{ form_end(resetForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
