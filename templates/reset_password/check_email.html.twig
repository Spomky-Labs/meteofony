{% extends 'base.html.twig' %}

{% block title %}An email has just been sent to you{% endblock %}

{% block nav %}{% endblock %}
{% block footer %}{% endblock %}
{% block bodytags %}class="bg-base-100 h-screen overflow-hidden"{% endblock %}

{% block body %}
    <div class="hero h-screen bg-base-200">
        <div class="hero-content flex-col lg:flex-row-reverse max-w-6xl w-full">
            <div class="flex-1 text-center lg:text-left">
                <img
                    src="{{ asset('images/Authentication-bro.svg') }}"
                    class="max-w-lg mx-auto drop-shadow-2xl"
                    alt="Check email illustration"
                />
            </div>
            <div class="flex-1">
                <div class="card bg-base-100 shadow-2xl">
                    <div class="card-body">
                        <h1 class="text-4xl font-bold text-center mb-6">
                            <i class="fa-solid fa-envelope-circle-check text-primary"></i>
                            Check Your Email
                        </h1>

                        <div class="alert alert-info mb-4">
                            <i class="fa-solid fa-circle-info"></i>
                            <p>If an account corresponding to your username exists, an email will be sent to you with the rest of the reset procedure.</p>
                        </div>

                        <div class="alert alert-warning mb-4">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <p>If you do not receive an email, please check your spam folder or <a href="{{ path('app_forgot_password_request') }}" class="link link-primary font-semibold">try again</a>.</p>
                        </div>

                        <div class="form-control mt-6">
                            <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg">
                                <i class="fa-solid fa-arrow-left"></i>
                                Back to Login
                            </a>
                        </div>

                        <div class="text-center mt-2">
                            <a href="{{ path('app_homepage') }}" class="link link-hover link-primary text-sm">
                                <i class="fa-solid fa-house"></i>
                                Back to Homepage
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
